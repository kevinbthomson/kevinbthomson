---
layout: layouts/base.njk
title: Home Page
---

{# <h1>{{ title }}</h1> #}

<div class="hero-banner" aria-hidden="true"></div>

<div class="container">
  <section>
    <p>
      Hi! 👋 I am a full-stack developer from Denver, Colorado. I'm
      currently working on a React component library for a global tax
      compliance software company: Sovos. I enjoy skiing, bicycling, hiking;
      just about everything outdoors except maybe rattlesnakes 🐍 😀
    </p>
  </section>

  <section aria-labeledby="section-title">
    <h2 id="section-title">Recent Posts</h2>
    {% include "partials/posts.njk" %}
  </section>

  <section aria-labeledby="section-title">
    <h2 id="section-title">Pages</h2>
    <ul>
      {% for page in collections.pages %}
        <li>
          <a href="{{ page.url }}">{{ page.data.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </section>
</div>